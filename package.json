{
  "name": "gumlet-modal-player",
  "private": true,
  "version": "1.3.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "clean": "npx rimraf dist",
    "build:embed": "vite build -c vite.config.modal.js",
    "build:modal": "vite build -c vite.config.modal.js",
    "build:pip": "vite build -c vite.config.pip.js",
    "build:all": "npm run clean && npm run build:modal && npm run build:pip",
    "build": "npm run build:all",
    "preview": "vite preview"
  },
  "dependencies": {
    "@gumlet/player.js": "^3.0.0"
  },
  "devDependencies": {
    "vite": "^5.4.0"
  }
}
